<!-- Generated by generator/generate.py from templates/builder.html.j2 — edit the template or data/diy_steps.json, not this file. -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>DIY Wizard - Sandbox</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="wizard.css">
</head>
<body>

    <a class="back-link" href="../index.html">&larr; Back to storefront</a>

    <div class="wizard">
        <div class="wizard-visual">
            <p class="wizard-kicker">DIY Wizard</p>
            <h1>Build Your Cabinet</h1>
            <p class="wizard-sub">Sandbox mode — pricing shown is placeholder data.</p>
            <div class="wizard-image"></div>
        </div>

        <form class="wizard-panel" id="wizard-form">
{% for step in steps %}
            <fieldset class="wizard-step">
                <legend>Step {{ step.number }}: {{ step.title }}</legend>
{% if step.kind == 'choice' %}
{% for option in step.options %}
                <label class="wizard-option">
                    <input type="radio" name="{{ step.field }}" value="{{ option.label }}" data-price="{{ option.price }}"{% if loop.first %} checked{% endif %}>
                    <span class="wizard-option-label">{{ option.label }}</span>
                    <span class="wizard-option-price">{% if option.price == 0 %}Included{% else %}+${{ '%.2f'|format(option.price) }}{% endif %}</span>
                </label>
{% endfor %}
{% elif step.kind == 'dimensions' %}
                <div class="wizard-dims">
                    <label>Width (in)<input type="number" name="width" min="1" step="0.25" value="24" required></label>
                    <label>Height (in)<input type="number" name="height" min="1" step="0.25" value="30" required></label>
                    <label>Depth (in)<input type="number" name="depth" min="1" step="0.25" value="24" required></label>
                </div>
                <span class="wizard-option-price">Included</span>
{% elif step.kind == 'text' %}
                <input type="text" class="wizard-text" name="{{ step.field }}" placeholder="e.g. Kitchen, Left of Sink" required>
{% endif %}
            </fieldset>
{% endfor %}

            <fieldset class="wizard-step">
                <legend>Quantity</legend>
                <input type="number" id="quantity" name="quantity" min="1" value="1" required>
            </fieldset>

            <div class="wizard-totals">
                <div><span>Cabinet Total</span><strong id="cabinet-total">$0.00</strong></div>
                <div><span>Rolling Total</span><strong id="rolling-total">$0.00</strong></div>
            </div>

            <p class="wizard-note" id="save-note" hidden></p>

            <div class="wizard-actions">
                <button type="submit" class="btn" id="submit-quote">Submit Quote</button>
                <button type="reset" class="btn-secondary">Restart</button>
                <button type="button" class="btn-secondary" id="save-close">Save &amp; Close</button>
                <button type="button" class="btn-secondary" id="save-next">Save &amp; Next Cabinet</button>
            </div>
        </form>
    </div>

    <script src="wizard.js" defer></script>
</body>
</html>
