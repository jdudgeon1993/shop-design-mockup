# Copy this to .env for local testing, or set each of these as Railway
# environment variables in the deployed service. Never commit a real .env.

PORT=3000

# From the JaaS console (developer.8x8.com) — the same AppID already used
# in dashboard/index.html and consultation/index.html.
JAAS_APP_ID=vpaas-magic-cookie-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "kid" from your JaaS API key — looks like <app-id>/<key-name>.
JAAS_KID=vpaas-magic-cookie-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx/xxxxx-SAMPLE_APP

# The private key downloaded when you generated that API key in the JaaS
# console. Paste it as a single line with \n in place of real newlines —
# the server converts them back automatically.
JAAS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----"

# Your Supabase project — Settings -> API in the Supabase dashboard.
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-public-key

# The site origin allowed to call this service (CORS). Use your real
# GitHub Pages / custom domain, e.g. https://jdudgeon1993.github.io
ALLOWED_ORIGIN=https://example.github.io
